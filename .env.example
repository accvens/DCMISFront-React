# Optional. If unset during `npm run dev`, the app uses /api/v1 on the Vite server
# and vite.config.js proxies /api → http://127.0.0.1:8000 (FastAPI).
#
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000
#
# Force a full API URL instead of the proxy (e.g. production or custom setup):
# VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1
